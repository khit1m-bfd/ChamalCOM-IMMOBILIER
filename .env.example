# ─────────────────────────────────────────
# ChamalCom — Environment Variables
# ─────────────────────────────────────────

# App
APP_NAME=ChamalCom
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost
FRONTEND_URL=http://localhost:3000

# Database
DB_DATABASE=chamalcom
DB_USERNAME=chamalcom_user
DB_PASSWORD=chamalcom_secret

# Redis
REDIS_PASSWORD=chamalcom_redis

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_TTL=60
JWT_REFRESH_TTL=20160

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Stripe
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Mail
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS=noreply@chamalcom.ma
MAIL_FROM_NAME="ChamalCom"

# pgAdmin (dev)
PGADMIN_EMAIL=admin@chamalcom.ma
PGADMIN_PASSWORD=admin

# Next.js Public
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
